{
  "title": "Контекстные правила чтения",
  "items": [
    {
      "diphthong": "αι",
      "sound_ru": "обычно как «э»",
      "examples": [
        { "word": "αίμα", "ru": "кровь" },
        { "word": "αιώνιος", "ru": "вечный" },
        { "word": "καιρός", "ru": "погода; время (подходящий момент)" },
        { "word": "παιδιά", "ru": "дети" }
      ]
    },
    {
      "diphthong": "ει",
      "sound_ru": "обычно как «и»",
      "examples": [
        { "word": "είμαι", "ru": "я есть" },
        { "word": "είδος", "ru": "вид; тип" },
        { "word": "κείμενο", "ru": "текст" },
        { "word": "δείχνω", "ru": "показываю" }
      ]
    },
    {
      "diphthong": "οι",
      "sound_ru": "обычно как «и»",
      "examples": [
        { "word": "οίκος", "ru": "дом (книжн.); род" },
        { "word": "οίνος", "ru": "вино (книжн.)" },
        { "word": "κοίτα", "ru": "смотри" },
        { "word": "αυτοί", "ru": "они (эти)" }
      ]
    },
    {
      "diphthong": "υι",
      "sound_ru": "обычно как «и» (редко, чаще в корне υι-)",
      "examples": [
        { "word": "υιός", "ru": "сын" },
        { "word": "υιοθετώ", "ru": "усыновляю; принимаю" },
        { "word": "υιοθεσία", "ru": "усыновление" }
      ]
    },
    {
      "diphthong": "ου",
      "sound_ru": "как «у»",
      "examples": [
        { "word": "ουρανός", "ru": "небо" },
        { "word": "ούτε", "ru": "ни; даже не" },
        { "word": "λουλούδι", "ru": "цветок" },
        { "word": "κουτί", "ru": "коробка" }
      ]
    },
    {
      "diphthong": "αυ",
      "sound_ru": "перед звонкими/гласными чаще «ав», перед глухими чаще «аф»",
      "examples": [
        { "word": "αύριο", "ru": "завтра" },
        { "word": "αυγό", "ru": "яйцо" },
        { "word": "αυτό", "ru": "это; этот" },
        { "word": "καυτός", "ru": "горячий" }
      ]
    },
    {
      "diphthong": "ευ",
      "sound_ru": "перед звонкими/гласными чаще «эв», перед глухими чаще «эф»",
      "examples": [
        { "word": "Ευρώπη", "ru": "Европа" },
        { "word": "ευχαριστώ", "ru": "спасибо" },
        { "word": "νεύρο", "ru": "нерв" },
        { "word": "αλεύρι", "ru": "мука" }
      ]
    },
    {
      "diphthong": "ηυ",
      "sound_ru": "перед звонкими/гласными чаще «ив», перед глухими чаще «иф» (редко)",
      "examples": [
        { "word": "ηύξησα", "ru": "я увеличил(а); я вырос(ла)" },
        { "word": "απηύδησα", "ru": "мне осточертело; я очень устал(а)" }
      ]
    },
    {
      "diphthong": "μπ",
      "sound_ru": "в начале слова обычно «б», в середине часто «мб»",
      "examples": [
        { "word": "μπαίνω", "ru": "вхожу" },
        { "word": "μπαμπάς", "ru": "папа" },
        { "word": "λάμπα", "ru": "лампа" },
        { "word": "εμπόριο", "ru": "торговля" }
      ]
    },
    {
      "diphthong": "ντ",
      "sound_ru": "в начале слова обычно «д», в середине часто «нд»",
      "examples": [
        { "word": "ντομάτα", "ru": "помидор" },
        { "word": "ντουλάπα", "ru": "шкаф" },
        { "word": "πάντα", "ru": "всегда" },
        { "word": "αντί", "ru": "против; вместо" }
      ]
    },
    {
      "diphthong": "γκ",
      "sound_ru": "в начале слова обычно «г», в середине часто «нг» + «г» (с носовым оттенком)",
      "examples": [
        { "word": "γκάζι", "ru": "газ; ускорение (разг.)" },
        { "word": "γκρίζος", "ru": "серый" },
        { "word": "αγκάθι", "ru": "шип; колючка" },
        { "word": "άγκυρα", "ru": "якорь" }
      ]
    },
    {
      "diphthong": "γγ",
      "sound_ru": "обычно «нгг» (как «нг» + «г»)",
      "examples": [
        { "word": "άγγελος", "ru": "ангел" },
        { "word": "συγγνώμη", "ru": "извини(те)" },
        { "word": "εγγύηση", "ru": "гарантия" }
      ]
    },
    {
      "diphthong": "γχ",
      "sound_ru": "обычно «нгх» (как носовое «нг» + «х»)",
      "examples": [
        { "word": "άγχος", "ru": "тревога; стресс" },
        { "word": "συγχρόνως", "ru": "одновременно" },
        { "word": "έλεγχος", "ru": "проверка; контроль" }
      ]
    },
    {
      "diphthong": "τσ",
      "sound_ru": "как «ц»",
      "examples": [
        { "word": "τσάι", "ru": "чай" },
        { "word": "τσέπη", "ru": "карман" },
        { "word": "κάτσε", "ru": "сядь" },
        { "word": "έτσι", "ru": "так" }
      ]
    },
    {
      "diphthong": "τζ",
      "sound_ru": "как «дз» (иногда ближе к «дж» в заимствованиях)",
      "examples": [
        { "word": "τζάμι", "ru": "стекло; оконное стекло" },
        { "word": "τζάκετ", "ru": "куртка; пиджак (заимств.)" },
        { "word": "πατζάρι", "ru": "свёкла" },
        { "word": "γκατζέτ", "ru": "гаджет (заимств.)" }
      ]
    },
    {
      "diphthong": "γ + {ε, αι, η, ι, υ, ει, οι}",
      "sound_ru": "мягкий звук, близкий к «й» (часто слышится как «й», иногда чуть «трётся»)",
      "examples": [
        { "word": "για", "ru": "для" },
        { "word": "γεια", "ru": "привет" },
        { "word": "γίνομαι", "ru": "становлюсь" },
        { "word": "γυμνάσιο", "ru": "гимназия; школа" }
      ]
    },
    {
      "diphthong": "κ + {ε, αι, η, ι, υ, ει, οι}",
      "sound_ru": "смягчённое «к» (примерно «кь»)",
      "examples": [
        { "word": "και", "ru": "и" },
        { "word": "κίτρινο", "ru": "жёлтый" },
        { "word": "εκεί", "ru": "там" },
        { "word": "εκείνος", "ru": "тот (он)" }
      ]
    },
    {
      "diphthong": "χ + {ε, αι, η, ι, υ, ει, οι}",
      "sound_ru": "смягчённое «х» (примерно «хь»)",
      "examples": [
        { "word": "χέρι", "ru": "рука" },
        { "word": "χειμώνας", "ru": "зима" },
        { "word": "ευχή", "ru": "пожелание; молитва" },
        { "word": "συνεχίζω", "ru": "продолжаю" }
      ]
    },
    {
      "diphthong": "σ + {β, γ, δ, μ, ν, λ, ρ, ζ}",
      "sound_ru": "часто озвончается и звучит ближе к «з» (особенно в быстрой речи)",
      "examples": [
        { "word": "σβήνω", "ru": "гашу; выключаю" },
        { "word": "σγουρός", "ru": "кудрявый" },
        { "word": "σμύρνα", "ru": "Смирна (Измир, историч.)" },
        { "word": "ασβέστης", "ru": "известь" }
      ]
    },
    {
      "diphthong": "{μπ, ντ, γκ} (в начале слова)",
      "sound_ru": "в начале слова читаются как «б», «д», «г» соответственно",
      "examples": [
        { "word": "μπαίνω", "ru": "вхожу" },
        { "word": "ντομάτα", "ru": "помидор" },
        { "word": "γκρίζος", "ru": "серый" },
        { "word": "γκάζι", "ru": "газ; ускорение (разг.)" }
      ]
    }
  ]
}